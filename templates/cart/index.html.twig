{% extends 'base.html.twig' %}

{% block title %}Mon panier - GreenGoodies{% endblock %}

{% block body %}
<section class="cart-section d-flex justify-content-center">
    <div class="container d-flex flex-column align-items-center">

        <!-- Titre + lien vider -->
        <h1 class="cart-title text-center">Mon panier</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success mt-3">{{ message }}</div>
        {% endfor %}

        {% if cartItems is empty %}
            <p class="mt-4">Votre panier est vide.</p>
        {% else %}

            <a href="{{ path('app_cart_clear') }}" class="cart-clear-link align-self-start">
                Vider le panier
            </a>

            <!-- Liste des produits -->
            <div class="cart-items-container d-flex flex-column gap-2">
                {% for item in cartItems %}
                    <div class="card cart-product-card border-0 d-flex flex-row align-items-center">
                        <img 
                            src="{{ asset('images/products/' ~ item.product.picture) }}"
                            alt="{{ item.product.name }}"
                            class="cart-product-img"
                        >
                        <div class="cart-product-text d-flex flex-column justify-content-center flex-grow-1">
                            <p class="cart-product-name mb-1">{{ item.product.name }}</p>
                            <p class="cart-product-qty mb-1">Quantité : {{ item.quantity }}</p>
                        </div>
                        <div class="cart-total-padding">
                            <p class="cart-product-price mb-0">
                                {{ item.subtotal|number_format(2, ',', ' ') }}€
                            </p>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Card total -->
            <div class="card cart-total-card border-0 mt-2">
                <div class="cart-total-wrapper d-flex align-items-center justify-content-between">
                    <div>
                        <p class="cart-total-label mb-0">Total</p>
                        <p class="cart-delivery cart-delivery-spacing mb-0">Livraison offerte</p>
                    </div>
                    <p class="cart-total-amount mb-0">{{ total|number_format(2, ',', ' ') }}€</p>
                </div>
            </div>

            <!-- Bouton valider -->
            <form action="{{ path('app_cart_validate') }}" method="post" class="mt-3">
                <input type="hidden" name="_token" value="{{ csrf_token('cart_validate') }}">
                <button type="submit" class="btn btn-secondary cart-btn">
                    Valider ma commande
                </button>
            </form>

        {% endif %}

    </div>
</section>
{% endblock %}

