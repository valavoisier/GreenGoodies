{% extends 'base.html.twig' %}

{% block title %}Panier - GreenGoodies{% endblock %}

{% block body %}
<section class="cart-section d-flex justify-content-center">
    <div class="container d-flex flex-column align-items-center">
        <!-- Titre -->
        <h1 class="cart-title text-center mb-3">Mon panier</h1>
        
        <!-- Messages flash -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success text-center" role="alert">
                {{ message }}
            </div>
        {% endfor %}
        
        {% if cartItems is empty %}
            <p class="text-center">Votre panier est vide.</p>
        {% else %}
            <!-- Liste des produits -->
            <div class="d-flex flex-column gap-1 cart-items-container">
                <a href="{{ path('app_cart_clear') }}" class="cart-clear-link d-inline-block">
                    x Vider le panier
                </a>

                {% for item in cartItems %}
                    <div class="card cart-product-card border-0 mx-auto">
                        <div class="row g-0 h-100">

                            <div class="col-auto d-flex align-items-center justify-content-center pt-3 ps-3 pb-4">
                                <img src="{{ asset('images/products/' ~ item.product.picture) }}"
                                     class="cart-product-img"
                                     alt="{{ item.product.name }}">
                            </div>

                            <div class="col d-flex align-items-center cart-product-text">
                                <div class="card-body">
                                    <h5 class="cart-product-name mb-1">{{ item.product.name }}</h5>
                                    <p class="cart-product-qty mb-2">Quantité : {{ item.quantity }}</p>
                                    <p class="cart-product-price mb-0">
                                        {{ item.subtotal|number_format(2, ',', ' ') }} €
                                    </p>
                                </div>
                            </div>

                        </div>
                    </div>
                {% endfor %}

                <!-- Total -->
                <div class="card cart-total-card border-0">
                    <div class="cart-total-wrapper d-flex flex-column justify-content-center align-items-end cart-total-padding">
                        
                        <div class="d-flex align-items-center">
                            <span class="cart-total-label me-2">Total panier :</span>
                            <span class="cart-total-amount">{{ total|number_format(2, ',', ' ') }}€</span>
                        </div>

                        <p class="cart-delivery mb-0 me-2 cart-delivery-spacing">Frais de livraison : Offert</p>

                    </div>
                </div>

                <!-- Bouton Valider -->
                <div class="d-flex flex-column align-items-center mt-2">
                    <form action="{{ path('app_cart_validate') }}" method="post" class="m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_validate') }}">
                        <button type="submit" class="btn btn-secondary cart-btn mt-3">
                            Valider la commande
                        </button>
                    </form>
                </div>

            </div>

        {% endif %}
    </div>
</section>
{% endblock %}
